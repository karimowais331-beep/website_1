<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Premium Calculator</title>
    <link rel="stylesheet" href="styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <div class="calculator-container">
        <aside class="sidebar">
            <div class="sidebar-header">
                <div class="logo">
                    <i class="fas fa-calculator"></i>
                </div>
                <h1>Calculator</h1>
                <p>Premium Calculator</p>
            </div>
            
            <nav class="nav-menu">
                <button class="nav-item active" data-mode="standard" aria-label="Standard Mode">
                    <i class="fas fa-home"></i>
                    <span>Standard</span>
                </button>
                <button class="nav-item" data-mode="scientific" aria-label="Scientific Mode">
                    <i class="fas fa-flask"></i>
                    <span>Scientific</span>
                </button>
                <button class="nav-item" data-mode="history" aria-label="History">
                    <i class="fas fa-history"></i>
                    <span>History</span>
                </button>
                <button class="nav-item" data-mode="settings" aria-label="Settings">
                    <i class="fas fa-cog"></i>
                    <span>Settings</span>
                </button>
            </nav>
            
            <div class="history-card">
                <div class="history-header">
                    <span>History</span>
                    <button class="clear-history" aria-label="Clear History">Clear</button>
                </div>
                <div class="history-list" id="historyList">
                </div>
            </div>
            
            <div class="sidebar-footer">
                <div class="theme-selector">
                    <span>Theme</span>
                    <div class="theme-circles">
                        <button class="theme-circle active" data-theme="neon" style="background: linear-gradient(135deg, #FF2D95, #8B5CF6);" aria-label="Neon Theme"></button>
                        <button class="theme-circle" data-theme="blue" style="background: linear-gradient(135deg, #3B82F6, #06B6D4);" aria-label="Blue Theme"></button>
                        <button class="theme-circle" data-theme="green" style="background: linear-gradient(135deg, #10B981, #34D399);" aria-label="Green Theme"></button>
                        <button class="theme-circle" data-theme="orange" style="background: linear-gradient(135deg, #F59E0B, #EF4444);" aria-label="Orange Theme"></button>
                    </div>
                </div>
                <div class="keyboard-status" id="keyboardStatus">
                    <i class="fas fa-keyboard"></i>
                    <span>Keyboard Support</span>
                    <button class="status-indicator on" id="keyboardToggle" aria-label="Toggle Keyboard Support">ON</button>
                </div>
            </div>
        </aside>
        
        <main class="main-content">
            <div class="display-panel" id="calculatorPanel">
                <div class="display-top">
                    <div class="mode-badge" id="modeBadge">Standard</div>
                    <div class="angle-mode-display" id="angleModeDisplay">DEG</div>
                    <button class="dark-mode-toggle" id="mobileToggle" aria-label="Toggle Sidebar" style="display: none;">
                        <i class="fas fa-bars"></i>
                    </button>
                </div>
                <div class="expression" id="expression">0</div>
                <div class="result" id="result">0</div>
                <div class="display-bottom">
                    <div class="current-time" id="currentTime">
                        <i class="far fa-clock"></i> 00:00
                    </div>
                    <div class="current-date" id="currentDate">
                        <i class="far fa-calendar"></i> Jan 01, 2024
                    </div>
                </div>
            </div>
            
            <div class="scientific-buttons" id="scientificButtons">
                <button class="btn scientific angle-toggle active" data-angle-mode="DEG" aria-label="Degree Mode">DEG</button>
                <button class="btn scientific angle-toggle" data-angle-mode="RAD" aria-label="Radian Mode">RAD</button>
                <button class="btn scientific" data-func="sin" aria-label="Sine">sin</button>
                <button class="btn scientific" data-func="cos" aria-label="Cosine">cos</button>
                <button class="btn scientific" data-func="tan" aria-label="Tangent">tan</button>
                <button class="btn scientific" data-func="log" aria-label="Logarithm">log</button>
                <button class="btn scientific" data-func="ln" aria-label="Natural Log">ln</button>
                <button class="btn scientific" data-func="sqrt" aria-label="Square Root">√</button>
                <button class="btn scientific" data-func="square" aria-label="Square">x²</button>
                <button class="btn scientific" data-func="pow" aria-label="Power">xʸ</button>
                <button class="btn scientific" data-func="fact" aria-label="Factorial">!</button>
                <button class="btn scientific" data-value="π" aria-label="Pi">π</button>
                <button class="btn scientific" data-value="e" aria-label="Euler's number">e</button>
            </div>
            
            <div class="button-grid" id="buttonGrid">
                <button class="btn special" data-action="clear" aria-label="Clear All">C</button>
                <button class="btn special" data-action="parentheses" aria-label="Parentheses">(</button>
                <button class="btn special" data-action="percent" aria-label="Percent">%</button>
                <button class="btn delete" data-action="delete" aria-label="Delete">
                    <i class="fas fa-backspace"></i>
                </button>
                
                <button class="btn number" data-value="7" aria-label="7">7</button>
                <button class="btn number" data-value="8" aria-label="8">8</button>
                <button class="btn number" data-value="9" aria-label="9">9</button>
                <button class="btn operator" data-value="/" aria-label="Divide">
                    <i class="fas fa-divide"></i>
                </button>
                
                <button class="btn number" data-value="4" aria-label="4">4</button>
                <button class="btn number" data-value="5" aria-label="5">5</button>
                <button class="btn number" data-value="6" aria-label="6">6</button>
                <button class="btn operator" data-value="*" aria-label="Multiply">
                    <i class="fas fa-times"></i>
                </button>
                
                <button class="btn number" data-value="1" aria-label="1">1</button>
                <button class="btn number" data-value="2" aria-label="2">2</button>
                <button class="btn number" data-value="3" aria-label="3">3</button>
                <button class="btn operator" data-value="-" aria-label="Subtract">
                    <i class="fas fa-minus"></i>
                </button>
                
                <button class="btn number wide" data-value="0" aria-label="0">0</button>
                <button class="btn number" data-value="." aria-label="Decimal">.</button>
                <button class="btn operator" data-value="+" aria-label="Add">
                    <i class="fas fa-plus"></i>
                </button>
                
                <button class="btn equals" data-action="equals" aria-label="Equals">
                    <i class="fas fa-equals"></i>
                    <span>Equals</span>
                </button>
            </div>

            <!-- History Panel -->
            <div class="history-panel" id="historyPanel" style="display: none;">
                <div class="settings-section">
                    <div class="settings-title">
                        <i class="fas fa-history"></i>
                        Calculation History
                    </div>
                    <div class="history-list-main" id="historyListMain">
                    </div>
                    <button class="btn" id="clearHistoryMain" style="width:100%; aspect-ratio: unset; height:50px;">
                        <i class="fas fa-trash"></i> Clear All History
                    </button>
                </div>
            </div>

            <!-- Settings Panel -->
            <div class="settings-panel" id="settingsPanel" style="display: none;">
                <div class="settings-section">
                    <div class="settings-title">
                        <i class="fas fa-palette"></i>
                        Theme Settings
                    </div>
                    <div class="theme-options">
                        <div class="theme-option" data-theme="neon">
                            <div class="theme-dot" style="background: linear-gradient(135deg, #FF2D95, #8B5CF6);"></div>
                            <span>Neon</span>
                        </div>
                        <div class="theme-option" data-theme="blue">
                            <div class="theme-dot" style="background: linear-gradient(135deg, #3B82F6, #06B6D4);"></div>
                            <span>Blue</span>
                        </div>
                        <div class="theme-option" data-theme="green">
                            <div class="theme-dot" style="background: linear-gradient(135deg, #10B981, #34D399);"></div>
                            <span>Green</span>
                        </div>
                        <div class="theme-option" data-theme="orange">
                            <div class="theme-dot" style="background: linear-gradient(135deg, #F59E0B, #EF4444);"></div>
                            <span>Orange</span>
                        </div>
                    </div>
                </div>
                
                <div class="settings-section">
                    <div class="settings-title">
                        <i class="fas fa-cog"></i>
                        Calculator Settings
                    </div>
                    <div class="select-row">
                        <span class="toggle-label">Decimal Precision</span>
                        <select class="precision-select" id="precisionSelect">
                            <option value="0">0</option>
                            <option value="1">1</option>
                            <option value="2" selected>2</option>
                            <option value="3">3</option>
                            <option value="4">4</option>
                            <option value="5">5</option>
                            <option value="6">6</option>
                        </select>
                    </div>
                    <div class="toggle-row">
                        <span class="toggle-label">Keyboard Support</span>
                        <div class="toggle-switch" id="keyboardToggleSettings">
                            <div class="toggle-slider"></div>
                        </div>
                    </div>
                </div>

                <div class="settings-section">
                    <div class="settings-title">
                        <i class="fas fa-info-circle"></i>
                        About
                    </div>
                    <div class="about-section">
                        <div class="about-info">
                            <div class="app-name">Premium Calculator</div>
                            <div class="app-version">Version 1.0</div>
                            <div class="app-tech">HTML • CSS • JavaScript</div>
                        </div>
                    </div>
                </div>
            </div>

        </main>
    </div>
    
    <script src="script.js"></script>
</body>
</html>
